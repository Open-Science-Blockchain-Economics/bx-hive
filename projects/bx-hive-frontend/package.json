{
  "name": "bx-hive-frontend",
  "version": "0.1.0",
  "author": {
    "name": "David Rojas",
    "email": "lempira@gmail.com"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0",
    "npm": ">=9.0"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^7.0.0-beta.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.11",
    "@types/react-dom": "^18.2.4",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "happy-dom": "^20.9.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.1.6",
    "vite": "^7.3.2",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^10.0.0-beta.2",
    "@blockshake/defly-connect": "^1.2.1",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@perawallet/connect": "^1.4.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@txnlab/use-wallet": "^4.6.0",
    "@txnlab/use-wallet-react": "^4.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "notistack": "^3.0.1",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.6.2"
  },
  "scripts": {
    "generate:app-clients": "algokit project link --all",
    "dev": "npm run generate:app-clients && vite",
    "dev:localnet-dev": "npm run generate:app-clients && vite --mode localnet-dev",
    "dev:localnet-prod": "npm run generate:app-clients && vite --mode localnet-prod",
    "build": "vite build",
    "build:localnet-dev": "tsc && vite build --mode localnet-dev",
    "build:localnet-prod": "tsc && vite build --mode localnet-prod",
    "build:testnet": "tsc && vite build --mode testnet",
    "build:mainnet": "tsc && vite build --mode mainnet",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "preview": "vite preview",
    "seed:localnet": "tsx --tsconfig tsconfig.scripts.json scripts/seed-localnet.ts",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:integration": "vitest --config vitest.integration.config.ts --run",
    "dev:e2e": "npm run generate:app-clients && VITE_E2E_MODE=true vite --mode e2e --port 5174 --strictPort",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "SLOW_MO=500 playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "ws@>7.0.0 <7.5.9": "7.5.10"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
