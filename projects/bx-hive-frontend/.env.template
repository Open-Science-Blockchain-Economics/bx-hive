# =====================================================================
# bx-hive frontend env template
# =====================================================================
# This is the only env file committed to the repo. Copy it to .env to set
# up the default LocalNet workflow, or to .env.<network> to target one of
# the named environments below.
#
# Vite mode → file mapping
#   pnpm dev                 → .env (LocalNet @ localhost)
#   pnpm dev:localnet-dev    → .env + .env.localnet-dev (hosted dev)
#   pnpm dev:localnet-prod   → .env + .env.localnet-prod (hosted prod-style)
#   pnpm build:testnet       → .env + .env.testnet (algonode testnet)
#   pnpm build:mainnet       → .env + .env.mainnet (algonode mainnet)
#
# After running `algokit project deploy <network>` in
# projects/bx-hive-contracts, copy the printed Registry / TrustExperiments
# app IDs into the matching .env.<network> file's VITE_REGISTRY_APP_ID
# and VITE_TRUST_EXPERIMENTS_APP_ID.
# =====================================================================

# ---- LocalNet (default — AlgoKit localnet on localhost) -------------
VITE_ENVIRONMENT=local

VITE_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
VITE_ALGOD_SERVER=http://localhost
VITE_ALGOD_PORT=4001
VITE_ALGOD_NETWORK=localnet

VITE_INDEXER_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
VITE_INDEXER_SERVER=http://localhost
VITE_INDEXER_PORT=8980

# KMD is LocalNet-only; the wallet provider ignores these on other networks.
# AlgoKit LocalNet starts with one wallet ("unencrypted-default-wallet")
# pre-funded with test ALGO.
VITE_KMD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
VITE_KMD_SERVER=http://localhost
VITE_KMD_PORT=4002
VITE_KMD_WALLET="unencrypted-default-wallet"
VITE_KMD_PASSWORD=""

# Populate from contracts deploy output.
VITE_REGISTRY_APP_ID=
VITE_TRUST_EXPERIMENTS_APP_ID=

# E2E test mode (Playwright)
# When "true", the app auto-connects the KMD wallet to the account passed via
# the `e2e-account` URL query parameter, skipping the wallet-connect modal.
# Set automatically by the dev:e2e script — leave unset for normal dev.
# VITE_E2E_MODE=true